{
  "expo": {
    "name": "PDFX - PDF Editor & Viewer",
    "slug": "pdfx",
    "version": "1.0.0",
    "description": "Edit, annotate, sign and merge PDFs. 100% free. Works offline. No subscription, no account, no data upload.",
    "privacy": "public",
    "platforms": ["ios", "android"],
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0F",
    "primaryColor": "#6366F1",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pdfx.editor",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "PDFX needs access to your photo library to add images to PDFs.",
        "NSCameraUsageDescription": "PDFX needs camera access to scan documents.",
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "PDF Document",
            "CFBundleTypeRole": "Editor",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": ["com.adobe.pdf"]
          }
        ],
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.adobe.pdf",
            "UTTypeDescription": "PDF Document",
            "UTTypeConformsTo": ["public.data"]
          }
        ]
      }
    },
    "android": {
      "package": "com.pdfx.editor",
      "versionCode": 1,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_DOCUMENTS",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.MANAGE_DOCUMENTS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [
            { "scheme": "content", "mimeType": "application/pdf" },
            { "scheme": "file", "mimeType": "application/pdf" }
          ]
        },
        {
          "action": "SEND",
          "category": ["DEFAULT"],
          "data": [{ "mimeType": "application/pdf" }]
        }
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.GET_ACCOUNTS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "useLegacyPackaging": false
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "pdfx-editor"
      },
      "privacyPolicyUrl": "https://pdfx-app.github.io/privacy-policy/",
      "supportEmail": "support@pdfx.app"
    },
    "owner": "pdfx"
  }
}
